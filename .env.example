SECRET_KEY=change-me-in-production
GRAPPASAFE_DB=grappasafe.db

# Monitoring area (default: Monte Grappa, Semonzo takeoff)
AREA_LAT=45.85261987481419
AREA_LON=11.771344896002997
AREA_RADIUS_KM=19.0

# OGN / APRS receive login. The passcode is derived from the callsign, so set
# a short, unique callsign (a shared one gets kicked off APRS-IS).
APRS_USER=GSAFE1

# Notifications — Telegram (bot token + group) and email (SMTP server, sender,
# and the emergency recipient) are configured at runtime from the admin panel
# → Notifiche. Nothing to set here. The old TELEGRAM_*/SMTP_*/NOTIFY_EMAIL env
# vars still work as a fallback but are no longer part of the setup.

# Initial admin user, read by seed.py on first run
ADMIN_USER=admin
ADMIN_PASS=changeme
ADMIN_NOME=Admin
ADMIN_COGNOME=GrappaSafe
